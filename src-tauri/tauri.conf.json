{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MCP Fusion",
  "version": "0.1.1",
  "identifier": "com.mcp-fusion.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../src-frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MCP Fusion",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright © 2024 MCP Fusion",
    "category": "DeveloperTool",
    "shortDescription": "多协议融合编排平台",
    "longDescription": "MCP Fusion 是一个多协议融合编排平台，支持 MCP 协议的工作流可视化编排与执行。",
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true,
        "startMenuFolder": "MCP Fusion"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "background": null
      },
      "files": {}
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libappindicator3-1"],
        "files": {},
        "desktopTemplate": null
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "libappindicator-gtk3"],
        "files": {},
        "desktopTemplate": null
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2NDJEMzQxQzA3QjQ5RjYKUldUZFFaUHNMdW1QeUFyVWJhM1hEZ2I2VjZXcTdDVmR0RGh6eFhLcU1Hc3ltcHR4MGcK",
      "endpoints": [
        "https://releases.mcp-fusion.app/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}