# ============================================================
# MCP Fusion 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ----------------------------------------------------------
# LLM 配置（用于意图解析）
# ----------------------------------------------------------
# OpenAI-compatible API 端点
LLM_API_URL=https://api.openai.com/v1/chat/completions
# 或使用本地 Ollama 模型
# LLM_API_URL=http://localhost:11434/v1/chat/completions

# API Key
LLM_API_KEY=sk-your-api-key-here

# 模型名称
LLM_MODEL=gpt-4o-mini
# 或本地模型
# LLM_MODEL=qwen2.5:7b

# LLM 参数
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=30

# ----------------------------------------------------------
# 加密密钥（生产环境必须设置）
# ----------------------------------------------------------
MCP_FUSION_ENCRYPTION_KEY=your-random-encryption-key-here

# ----------------------------------------------------------
# 模板仓库配置
# ----------------------------------------------------------
MCP_FUSION_TEMPLATE_INDEX_URL=https://raw.githubusercontent.com/mcp-fusion/templates/main/index.json
MCP_FUSION_TEMPLATE_BASE_URL=https://raw.githubusercontent.com/mcp-fusion/templates/main

# GitHub/GitLab Token（可选，用于私有仓库）
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# GITLAB_TOKEN=glpat-xxxxxxxxxxxx

# ----------------------------------------------------------
# OpenTelemetry 配置
# ----------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mcp-fusion

# ----------------------------------------------------------
# 自动更新配置
# ----------------------------------------------------------
# 更新端点由 Tauri conf 管理，如需自定义可在此设置
# MCP_FUSION_UPDATE_ENDPOINT=https://releases.mcp-fusion.app